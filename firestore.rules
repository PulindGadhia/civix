rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helper Functions =====

    // Check if the requesting user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the requesting user owns this document
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Get the user's role from Firestore
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Check if the user is an administrator
    function isAdmin() {
      return isAuthenticated() && getUserRole() in ['administrator', 'municipal_admin'];
    }

    // Check if the user is a department officer
    function isOfficer() {
      return isAuthenticated() && getUserRole() == 'department_officer';
    }

    // Check if the user is a department officer or higher
    function isOfficerOrAbove() {
      return isAuthenticated() && getUserRole() in ['department_officer', 'administrator', 'municipal_admin'];
    }

    // Get the user's department from Firestore
    function getUserDepartment() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department;
    }

    // Check if the user has access to the given issue
    function canAccessIssue(issueId) {
      let issue = get(/databases/$(database)/documents/issues/$(issueId)).data;
      return isAdmin() || 
        (isOfficer() && issue.department == getUserDepartment()) || 
        (isAuthenticated() && (issue.ownerUid == request.auth.uid || issue.citizenId == request.auth.uid));
    }

    // ===== Users Collection =====
    match /users/{userId} {
      allow read: if isOwner(userId) || isOfficerOrAbove();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status'])
        || isAdmin();
      allow delete: if isAdmin();
    }

    // ===== Issues Collection =====
    match /issues/{issueId} {
      allow read: if isAdmin() || 
        (isOfficer() && resource.data.department == getUserDepartment()) || 
        (isAuthenticated() && (resource.data.ownerUid == request.auth.uid || resource.data.citizenId == request.auth.uid));

      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;

      allow update: if isAdmin() || 
        (isOfficer() && resource.data.officer_id == request.auth.uid) || 
        (isAuthenticated() && (resource.data.ownerUid == request.auth.uid || resource.data.citizenId == request.auth.uid));

      allow delete: if isAdmin();
    }

    // ===== Issue Comments Collection =====
    match /issue_comments/{commentId} {
      allow read: if isAuthenticated() && canAccessIssue(resource.data.issue_id);
      allow create: if isAuthenticated() && canAccessIssue(request.resource.data.issue_id);
      allow update, delete: if isAuthenticated() && 
        (resource.data.author_id == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin());
    }

    // ===== Issue Verifications Collection =====
    match /issue_verifications/{verificationId} {
      allow read: if isAuthenticated() && canAccessIssue(resource.data.issue_id);
      allow create: if isAuthenticated() && canAccessIssue(request.resource.data.issue_id);
      allow update, delete: if isAuthenticated() && 
        (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin());
    }

    // ===== Issue Status History Collection =====
    match /issue_status_history/{historyId} {
      allow read: if isAuthenticated() && canAccessIssue(resource.data.issue_id);
      allow create: if isOfficerOrAbove() && canAccessIssue(request.resource.data.issue_id);
      allow update, delete: if isAdmin();
    }

    // ===== Issue Notifications Collection =====
    match /issue_notifications/{notificationId} {
      allow read: if isAuthenticated() && 
        (resource.data.ownerUid == request.auth.uid || 
         (isOfficer() && resource.data.department == getUserDepartment()) || 
         isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // ===== Departments Collection =====
    match /departments/{departmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===== Officers Collection =====
    match /officers/{officerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===== Default Deny =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
